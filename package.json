{
  "name": "agadmator-mcp",
  "version": "0.1.0",
  "description": "MCP server to search agadmator's chess video catalogue — by player, opening, ECO, year, move count, and move-level filters like queen sacrifices.",
  "type": "module",
  "bin": {
    "agadmator-mcp": "src/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josephwilliams/agadmator-search.git"
  },
  "homepage": "https://github.com/josephwilliams/agadmator-search#readme",
  "bugs": {
    "url": "https://github.com/josephwilliams/agadmator-search/issues"
  },
  "files": [
    "src",
    "data/index.json",
    "data/player-portraits.json"
  ],
  "scripts": {
    "build-index": "node scripts/build-index.mjs",
    "fetch-player-portraits": "node scripts/fetch-player-portraits.mjs",
    "start": "node src/server.js",
    "query": "node bin/query.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chess",
    "agadmator",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  }
}
